# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="InvestiGator"
APP_ENV="development"          # development | production
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default dev)
DATABASE_URL="sqlite:///./investigator.db"
# PostgreSQL (production example)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/investigator"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY="CHANGE_ME_GENERATE_A_STRONG_64_BYTE_HEX_SECRET"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AES-256 Encryption ────────────────────────────────────────────────────────
# 32 random bytes, base64-encoded
# Generate with: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
AES_MASTER_KEY="CHANGE_ME_GENERATE_A_STRONG_32_BYTE_BASE64_KEY"

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT="5/minute"
AUTH_HOUR_LIMIT="10/hour"

# ── OAuth2 (Optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
