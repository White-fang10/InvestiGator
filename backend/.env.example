# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="InvestiGator"
APP_ENV="development"
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite+aiosqlite:///./investigator.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/investigator"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY="CHANGE_ME_GENERATE_A_STRONG_64_BYTE_HEX_SECRET"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AES-256 Encryption ────────────────────────────────────────────────────────
# Generate: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
AES_MASTER_KEY="CHANGE_ME_GENERATE_A_STRONG_32_BYTE_BASE64_KEY"

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:5174"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT="10/minute"
AUTH_HOUR_LIMIT="30/hour"

# ── Redis (set REDIS_ENABLED=true if Redis is running) ────────────────────────
REDIS_URL="redis://localhost:6379/0"
REDIS_ENABLED=false

# ── Market Data APIs (fill in when you get keys) ──────────────────────────────
METAL_PRICE_API_KEY=""
ALPHA_VANTAGE_API_KEY=""

# ── Ollama AI ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="deepseek-r1:1.5b"

# ── OAuth2 (Optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
